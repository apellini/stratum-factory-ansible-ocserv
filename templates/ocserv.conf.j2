# ocserv.conf — managed by Ansible (stratum-factory-ansible-ocserv)
# DO NOT edit this file manually; changes will be overwritten on next run.

# Authentication: PAM — VPN users are Linux system accounts.
# User accounts are managed separately (stratum-factory-ansible-bastion-users).
auth = "pam"

# TLS certificate and private key (self-signed, generated by role)
server-cert = {{ ocserv_cert_dir }}/server.crt
server-key = {{ ocserv_cert_dir }}/server.key

# Listening ports (TCP for TLS handshake + DTLS data, UDP for DTLS fast-path)
tcp-port = {{ ocserv_port }}
udp-port = {{ ocserv_port }}

# Bind only to the resolved external NIC IP (D-INFRA-22)
listen-host = {{ _ocserv_listen_host }}
listen-host-is-dyndns = false

# Connection limits
max-clients = {{ ocserv_max_clients }}
max-same-client = {{ ocserv_max_same_client }}

# Compression
compression = {{ ocserv_compression | lower }}
no-compress-limit = 256

# TUN device naming
device = vpns
predictable-ips = true

# Search domain pushed to clients
default-domain = stratum.dev

# VPN address pool assigned to clients
ipv4-network = {{ ocserv_vpn_network }}
ipv4-netmask = {{ ocserv_vpn_netmask }}

# DNS pushed to clients
dns = {{ ocserv_dns }}

ping-leases = false

# Routes pushed to VPN clients (internal STRATUM VPC segments)
{% for route in ocserv_pushed_routes %}
route = {{ route }}
{% endfor %}

# AnyConnect / Cisco compatibility
cisco-client-compat = true
dtls-legacy = true

# Run as unprivileged user after binding
run-as-user = nobody
run-as-group = daemon

# Isolate worker processes for each client session
isolate-workers = true

# Socket and PID paths
socket-file = /var/run/ocserv-socket
pid-file = /var/run/ocserv.pid

# Logging
log-level = 1
